    {
      "collection_id": "transaksiKeuangan",
      "description": "Store financial transaction records",
      "document_schema": {
        "siswaId": "string",
        "namaSiswaManual": "string",
        "jenis": "string",
        "jumlah": "number",
        "tanggal": "string",
        "status": "string",
        "keterangan": "string"
      }
    }
