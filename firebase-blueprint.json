        "hari": ["string"],
        "jam": "string"
      }
    },
    {
      "collection_id": "hariLibur",
      "description": "Store holiday data",
      "document_schema": {
        "bulan": "string",
        "tanggal": "string",
        "shiftId": "string",
        "kelasId": "string",
        "keterangan": "string"
      }
    },
    {
      "collection_id": "kelas",
