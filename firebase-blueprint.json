        "tanggalLulus": "string",
        "statusKhatam": "boolean",
        "tanggalKhatam": "string",
        "nilaiKhatam": "string",
        "nomorSertifikat": "string"
      }
    },
    {
      "collection_id": "guruBTQ",
      "description": "Store all Guru BTQ data",
      "document_schema": {
        "namaLengkap": "string",
        "gender": "string",
        "tempatLahir": "string",
        "tanggalLahir": "string",
        "kodeGuru": "string"
      }
    },
    {
      "collection_id": "guruBinaan",
      "description": "Store all Guru Binaan data",
      "document_schema": {
        "namaLengkap": "string",
